# ─────────────────────────────────────────────────────────────────────────
# LEADer environment — copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection. Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://leader:leader@localhost:5432/leader?schema=public"

# ── Auth (real, session-backed, multi-user) ───────────────────────────────
# Sessions are opaque tokens stored (hashed) in Postgres — no extra secret
# needed. Register at /register, or sign in as the seeded user (below).
DEV_USER_EMAIL="owner@leader.local"
# Password for the seeded power user (printed by `npm run db:seed`).
SEED_PASSWORD="leader-demo-1234"
# Local-only: set to "true" to bypass login and run as the seeded user.
# IGNORED in production. Leave unset to require real login.
AUTH_DEV_BYPASS=""
# Public base URL (used in alert emails / links).
APP_URL="http://localhost:3000"

# ── AI layer (OpenAI-compatible; provider-agnostic) ───────────────────────
# Leave LLM_API_KEY empty to run fully offline with deterministic MOCK output.
# Point LLM_BASE_URL at any OpenAI-compatible endpoint (OpenAI, Azure, local).
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
# Optional separate model for embeddings / similarity (future upgrade).
LLM_EMBEDDING_MODEL="text-embedding-3-small"

# ── Crawler / ingestion (PUBLIC sources only — see docs/COMPLIANCE.md) ─────
CRAWLER_USER_AGENT="LEADerBot/0.1 (+personal lead intelligence; respects robots.txt)"
CRAWLER_RATE_LIMIT_MS="2000"      # min delay between requests to the same host
CRAWLER_MAX_PAGES_PER_RUN="25"    # safety cap per discovery run
CRAWLER_TIMEOUT_MS="15000"
# Set to "true" only if you have a legitimate need for JS-rendered PUBLIC pages.
CRAWLER_ENABLE_PLAYWRIGHT="false"

# ── On-demand discovery search ────────────────────────────────────────────
# Discover works best with one web-search provider. Lida uses the first key
# available in this order: Tavily, Brave, Serper. Saved-source scans still work
# without these keys, but broad "search the web for leads" requires one.
TAVILY_API_KEY=""
BRAVE_SEARCH_API_KEY=""
SERPER_API_KEY=""

# ── Email (alerts / digests / deadline reminders) ─────────────────────────
# EMAIL_PROVIDER: "" (log-only/local alerts) | "resend" (real) | "console" (dev).
# With "resend", set EMAIL_API_KEY to a Resend API key and EMAIL_FROM to a
# verified sender. Empty keeps everything as in-app (LOCAL) alerts.
EMAIL_PROVIDER=""
EMAIL_API_KEY=""
EMAIL_FROM="LEADer <onboarding@resend.dev>"
# Deadline-reminder horizon in days.
REMINDER_WINDOW_DAYS="7"

# ── Cron protection ───────────────────────────────────────────────────────
# If set, the scheduler endpoints require header `x-cron-secret: <value>`:
#   POST /api/cron/discover   (run due discovery for all owners)
#   POST /api/cron/alerts     (deadline reminders + optional digest)
CRON_SECRET=""
