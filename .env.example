# ─────────────────────────────────────────────────────────────────────────
# LEADer environment — copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection. Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://leader:leader@localhost:5432/leader?schema=public"

# ── Auth (NextAuth-shaped seam; dev runs as the seeded power user) ─────────
# Used later when wiring real auth. Safe to leave default for local dev.
AUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"
# Dev convenience: the seeded user's email is treated as the current user.
DEV_USER_EMAIL="owner@leader.local"

# ── AI layer (OpenAI-compatible; provider-agnostic) ───────────────────────
# Leave LLM_API_KEY empty to run fully offline with deterministic MOCK output.
# Point LLM_BASE_URL at any OpenAI-compatible endpoint (OpenAI, Azure, local).
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
# Optional separate model for embeddings / similarity (future upgrade).
LLM_EMBEDDING_MODEL="text-embedding-3-small"

# ── Crawler / ingestion (PUBLIC sources only — see docs/COMPLIANCE.md) ─────
CRAWLER_USER_AGENT="LEADerBot/0.1 (+personal lead intelligence; respects robots.txt)"
CRAWLER_RATE_LIMIT_MS="2000"      # min delay between requests to the same host
CRAWLER_MAX_PAGES_PER_RUN="25"    # safety cap per discovery run
CRAWLER_TIMEOUT_MS="15000"
# Set to "true" only if you have a legitimate need for JS-rendered PUBLIC pages.
CRAWLER_ENABLE_PLAYWRIGHT="false"

# ── Email (alerts/digests) — v1 logs locally; wire a provider later ───────
# e.g. Resend / Postmark. Leave empty to keep notifications local-only.
EMAIL_PROVIDER=""
EMAIL_API_KEY=""
EMAIL_FROM="LEADer <alerts@leader.local>"

# ── Cron protection (optional) ────────────────────────────────────────────
# If set, /api/cron/discover requires header `x-cron-secret: <value>`.
CRON_SECRET=""
