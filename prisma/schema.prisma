// LEADer — Prisma schema (source of truth for the data model)
// Denmark-first, global-ready. Single power user now, multi-tenant-shaped (ownerId everywhere).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Workspace {
  DK
  GLOBAL
}

enum SourceType {
  PUBLIC_WEB // automatable
  RSS // automatable
  PROCUREMENT // automatable
  ACCELERATOR // automatable
  NEWSLETTER // automatable
  API // automatable
  FACEBOOK_MANUAL // manual-only (community lane)
  UPLOAD // manual-only
  MANUAL // manual-only
}

enum MonitorFrequency {
  MANUAL
  HOURLY
  DAILY
  WEEKLY
}

enum OpportunityStatus {
  NEW
  INTERESTING
  WATCH
  CONTACTED
  APPLIED
  WON
  LOST
  ARCHIVED
}

enum ApplicationRoute {
  DIRECT // direct contact / direct application
  APPLICATION // formal application process
  UNKNOWN
}

enum IngestMethod {
  AUTOMATED // public-source discovery
  MANUAL // user-created
  COMMUNITY // facebook/community import
}

enum DraftKind {
  SUMMARY
  APPLICATION
  PITCH
  EMAIL
  CHECKLIST
  COMPARISON
  EXPLANATION
}

enum ActivityType {
  CREATED
  STATUS_CHANGE
  NOTE
  AI_DRAFT
  SCORE
  EXPORT
  REMINDER
  IMPORT
  UPDATE
}

enum AlertType {
  DEADLINE
  NEW_HIGH_MATCH
  DIGEST
  NEEDS_ACTION
}

enum AlertChannel {
  LOCAL
  EMAIL
}

enum CommunityImportStatus {
  PENDING
  EXTRACTED
  CONFIRMED
  DISCARDED
}

enum DiscoveryFeedbackType {
  GOOD_RESULT
  NON_LEAD
}

enum AccountType {
  COMPANY
  STARTUP
  PUBLIC_BUYER
  COMMUNITY
  PARTNER
  PERSONA
  UNKNOWN
}

enum DealStatus {
  DISCOVERED
  QUALIFYING
  INTERESTING
  CONTACTED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum DiscoveryCandidateStatus {
  NEW
  REVIEWED
  SAVED
  DISMISSED
  DUPLICATE
}

enum EvidenceKind {
  SOURCE_SNIPPET
  WEB_RESULT
  STRUCTURED_DATA
  AI_EXTRACT
  USER_NOTE
}

enum TouchpointKind {
  CALL
  EMAIL
  MEETING
  NOTE
  COMMUNITY
  MESSAGE
  OTHER
}

enum TaskStatus {
  OPEN
  DONE
  DISMISSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ConversionAssetKind {
  OUTREACH
  PROPOSAL
  FOLLOW_UP
  CHECKLIST
  CALL_PREP
  PITCH
  SUMMARY
}

// ─────────────────────────────── Models ──────────────────────────────

enum UserRole {
  OWNER
  MEMBER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String? // scrypt hash; null = no password set yet (legacy/dev seed)
  role         UserRole  @default(OWNER)
  onboardedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Profile / preferences (drives scoring + AI context)
  headline              String? // e.g. "Fullstack dev · AI builder · MVP/product advisor"
  bio                   String?
  preferredProjectTypes String[] @default([])
  excludedCategories    String[] @default([])
  budgetMaxDkk          Int      @default(100000)
  preferredCurrency     String   @default("DKK")

  // JSON blobs (typed in lib/types.ts)
  scoringWeights Json? // ScoreWeights
  exportPrefs    Json? // ExportPreferences
  aiKeys         Json? // encrypted per-user AI provider config + masked key metadata

  sources             Source[]
  opportunities       Opportunity[]
  lists               List[]
  watchlistItems      WatchlistItem[]
  savedSearches       SavedSearch[]
  discoveryFeedback   DiscoveryFeedback[]
  alerts              Alert[]
  drafts              Draft[]
  notes               Note[]
  sessions            Session[]
  accounts            Account[]
  people              Person[]
  deals               Deal[]
  discoveryLanes      DiscoveryLane[]
  discoveryMissions   DiscoveryMission[]
  discoveryCandidates DiscoveryCandidate[]
  workflowRuns        WorkflowRun[]
  workflowPresets     WorkflowPreset[]
  workflowPresetEvents WorkflowPresetEvent[]
  evidence            Evidence[]
  touchpoints         Touchpoint[]
  tasks               Task[]
  conversionAssets    ConversionAsset[]
}

// Server-side sessions (opaque token hashed at rest). The auth cookie holds the
// raw token; we store only its SHA-256 so a DB leak can't resurrect sessions.
model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Source {
  id            String           @id @default(cuid())
  ownerId       String
  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  url           String?
  type          SourceType
  workspace     Workspace        @default(DK)
  frequency     MonitorFrequency @default(DAILY)
  keywords      String[]         @default([])
  country       String?          @default("DK")
  region        String?
  category      String?
  enabled       Boolean          @default(true)
  parserKey     String? // maps to a site-specific extractor in lib/ingestion/parsers
  robotsAllowed Boolean? // cached result of robots.txt check
  lastCheckedAt DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  opportunities Opportunity[]
  discoveryRuns DiscoveryRun[]
  deals         Deal[]

  @@index([ownerId, enabled])
  @@index([workspace])
}

model Opportunity {
  id       String  @id @default(cuid())
  ownerId  String
  owner    User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  title       String
  description String? @db.Text
  rawContent  String? @db.Text

  budgetMin Int?
  budgetMax Int?
  currency  String? @default("DKK")

  deadline  DateTime?
  postedAt  DateTime?
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  url          String?
  organization String?
  location     String?
  country      String?   @default("DK")
  region       String?
  category     String?
  workspace    Workspace @default(DK)

  status           OpportunityStatus @default(NEW)
  applicationRoute ApplicationRoute  @default(UNKNOWN)
  priority         Int               @default(0) // 0..3
  ingestMethod     IngestMethod      @default(MANUAL)

  matchScore            Int? // 0..100
  scoreBreakdown        Json? // ScoreBreakdown
  aiSummary             String? @db.Text
  whyRelevant           String? @db.Text
  nextAction            String? @db.Text
  extractedRequirements Json? // string[]

  // Semantic search: embedding vector + the model that produced it (only vectors
  // from the same model/dimension are comparable). Backfilled async; see lib/ai/embeddings.
  embedding      Float[]   @default([])
  embeddingModel String?
  embeddedAt     DateTime?

  dedupeHash String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts        Contact[]
  attachments     Attachment[]
  notes           Note[]
  activities      Activity[]
  drafts          Draft[]
  tags            OpportunityTag[]
  listItems       ListItem[]
  watchlistItem   WatchlistItem?
  communityImport CommunityImport?
  deal            Deal?

  @@index([ownerId, status])
  @@index([ownerId, workspace])
  @@index([matchScore])
  @@index([deadline])
  @@index([sourceId])
}

model Contact {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  name          String?
  role          String?
  email         String?
  phone         String?
  organization  String?
  linkedin      String?
  createdAt     DateTime    @default(now())
}

model Attachment {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  label         String?
  url           String
  kind          String? // pdf | link | doc | image
  createdAt     DateTime    @default(now())
}

model Tag {
  id            String           @id @default(cuid())
  name          String           @unique
  color         String?
  createdAt     DateTime         @default(now())
  opportunities OpportunityTag[]
}

model OpportunityTag {
  opportunityId String
  tagId         String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([opportunityId, tagId])
}

model Note {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body          String      @db.Text
  pinned        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model Activity {
  id            String       @id @default(cuid())
  opportunityId String
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type          ActivityType
  message       String
  metadata      Json?
  createdAt     DateTime     @default(now())

  @@index([opportunityId, createdAt])
}

model Draft {
  id             String      @id @default(cuid())
  opportunityId  String
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  kind           DraftKind
  title          String?
  content        String      @db.Text
  model          String?
  promptSnapshot String?     @db.Text
  createdAt      DateTime    @default(now())

  @@index([opportunityId, kind])
}

model List {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       ListItem[]

  @@index([ownerId])
}

model ListItem {
  id            String      @id @default(cuid())
  listId        String
  list          List        @relation(fields: [listId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  addedAt       DateTime    @default(now())

  @@unique([listId, opportunityId])
}

model WatchlistItem {
  id            String      @id @default(cuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  priority      Int         @default(1) // 1..3
  reminderAt    DateTime?
  createdAt     DateTime    @default(now())

  @@index([ownerId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  filters   Json // OpportunityFilter
  createdAt DateTime @default(now())

  @@index([ownerId])
}

model CommunityImport {
  id            String                @id @default(cuid())
  ownerId       String
  groupName     String?
  author        String?
  postDate      DateTime?
  url           String?
  content       String                @db.Text
  notes         String?
  status        CommunityImportStatus @default(PENDING)
  extracted     Json? // AI-extracted candidate fields
  opportunityId String?               @unique
  opportunity   Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  @@index([ownerId, status])
}

model Account {
  id          String      @id @default(cuid())
  ownerId     String
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  type        AccountType @default(UNKNOWN)
  website     String?
  domain      String?
  description String?     @db.Text
  country     String?
  region      String?
  workspace   Workspace   @default(DK)
  source      String?
  fitScore    Int?
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  people              Person[]
  deals               Deal[]
  evidence            Evidence[]
  touchpoints         Touchpoint[]
  tasks               Task[]
  conversionAssets    ConversionAsset[]
  discoveryCandidates DiscoveryCandidate[]

  @@unique([ownerId, name])
  @@index([ownerId, workspace])
  @@index([ownerId, type])
}

model Person {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  name      String?
  role      String?
  email     String?
  phone     String?
  linkedin  String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealLinks   DealPerson[]
  touchpoints Touchpoint[]
  tasks       Task[]

  @@unique([ownerId, email])
  @@index([ownerId])
  @@index([accountId])
}

model Deal {
  id                  String         @id @default(cuid())
  ownerId             String
  owner               User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountId           String?
  account             Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sourceId            String?
  source              Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  laneId              String?
  lane                DiscoveryLane? @relation(fields: [laneId], references: [id], onDelete: SetNull)
  legacyOpportunityId String?        @unique
  legacyOpportunity   Opportunity?   @relation(fields: [legacyOpportunityId], references: [id], onDelete: SetNull)

  title            String
  summary          String?          @db.Text
  rawContent       String?          @db.Text
  valueMin         Int?
  valueMax         Int?
  currency         String?          @default("DKK")
  deadline         DateTime?
  status           DealStatus       @default(DISCOVERED)
  priority         Int              @default(0)
  workspace        Workspace        @default(DK)
  category         String?
  applicationRoute ApplicationRoute @default(UNKNOWN)
  url              String?

  matchScore      Int?
  confidenceScore Int?
  pursuitScore    Int?
  qualification   Json?
  nextAction      String? @db.Text
  statusReason    String? @db.Text
  wonLostReason   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  people           DealPerson[]
  candidates       DiscoveryCandidate[]
  evidence         Evidence[]
  touchpoints      Touchpoint[]
  tasks            Task[]
  conversionAssets ConversionAsset[]

  @@index([ownerId, status])
  @@index([ownerId, workspace])
  @@index([accountId])
  @@index([deadline])
  @@index([pursuitScore])
}

model DealPerson {
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  role      String?
  createdAt DateTime @default(now())

  @@id([dealId, personId])
  @@index([personId])
}

model DiscoveryLane {
  id                   String       @id @default(cuid())
  ownerId              String
  owner                User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug                 String
  name                 String
  description          String       @db.Text
  workspace            Workspace    @default(DK)
  active               Boolean      @default(true)
  sourceTypes          SourceType[] @default([])
  queryTemplates       String[]     @default([])
  positiveKeywords     String[]     @default([])
  negativeKeywords     String[]     @default([])
  scoringConfig        Json?
  evidenceRequirements String[]     @default([])
  conversionGuidance   String?      @db.Text
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  missions   DiscoveryMission[]
  candidates DiscoveryCandidate[]
  deals      Deal[]

  @@unique([ownerId, slug])
  @@index([ownerId, active])
}

model DiscoveryMission {
  id              String        @id @default(cuid())
  ownerId         String
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  laneId          String
  lane            DiscoveryLane @relation(fields: [laneId], references: [id], onDelete: Cascade)
  query           String        @db.Text
  input           Json?
  workspace       Workspace     @default(DK)
  provider        String?
  status          String        @default("RUNNING")
  queuePriority   Int           @default(0)
  warnings        String[]      @default([])
  log             String[]      @default([])
  sourceScanCount Int           @default(0)
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  createdAt       DateTime      @default(now())

  candidates DiscoveryCandidate[]

  @@index([ownerId, startedAt])
  @@index([ownerId, status, queuePriority, startedAt])
  @@index([laneId, startedAt])
}

model DiscoveryCandidate {
  id        String            @id @default(cuid())
  ownerId   String
  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  laneId    String?
  lane      DiscoveryLane?    @relation(fields: [laneId], references: [id], onDelete: SetNull)
  missionId String?
  mission   DiscoveryMission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  accountId String?
  account   Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId    String?
  deal      Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)

  title            String
  description      String?          @db.Text
  rawContent       String?          @db.Text
  url              String?
  organization     String?
  workspace        Workspace        @default(DK)
  sourceName       String?
  sourceKind       String?
  provider         String?
  query            String?          @db.Text
  category         String?
  budgetMin        Int?
  budgetMax        Int?
  currency         String?          @default("DKK")
  deadline         DateTime?
  applicationRoute ApplicationRoute @default(UNKNOWN)

  status          DiscoveryCandidateStatus @default(NEW)
  matchScore      Int?
  confidenceScore Int?
  pursuitScore    Int?
  scoreBreakdown  Json?
  reasons         String[]                 @default([])
  signals         String[]                 @default([])
  feedback        Json?
  dismissalReason String?
  dedupeKey       String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  evidence         Evidence[]
  conversionAssets ConversionAsset[]

  @@index([ownerId, status])
  @@index([ownerId, workspace])
  @@index([laneId])
  @@index([missionId])
  @@index([pursuitScore])
}

model WorkflowRun {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  presetId   String?
  preset     WorkflowPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  trigger    String    @default("manual")
  playbook   String
  workspace  Workspace @default(DK)
  status     String    @default("QUEUED")
  queuePriority Int       @default(0)
  input      Json?
  result     Json?
  log        String[]  @default([])
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  presetEvents WorkflowPresetEvent[]

  @@index([ownerId, createdAt])
  @@index([ownerId, status])
  @@index([ownerId, status, queuePriority, createdAt])
  @@index([ownerId, trigger])
  @@index([presetId])
}

model WorkflowPreset {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  description  String?   @db.Text
  playbook     String
  workspace    Workspace @default(DK)
  options      Json?
  pinned       Boolean   @default(false)
  scheduleEnabled       Boolean   @default(false)
  scheduleIntervalHours Int       @default(24)
  scheduleNextRunAt     DateTime?
  lastScheduledAt       DateTime?
  lastQueuedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workflowRuns WorkflowRun[]
  events       WorkflowPresetEvent[]

  @@unique([ownerId, name])
  @@index([ownerId, pinned])
  @@index([ownerId, scheduleEnabled, scheduleNextRunAt])
  @@index([ownerId, updatedAt])
}

model WorkflowPresetEvent {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  presetId  String
  preset    WorkflowPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  runId     String?
  run       WorkflowRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  eventType String
  reason    String?
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([presetId, createdAt])
  @@index([runId])
  @@index([ownerId, eventType])
}

model Evidence {
  id          String              @id @default(cuid())
  ownerId     String
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  candidateId String?
  candidate   DiscoveryCandidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  kind        EvidenceKind
  url         String?
  title       String?
  snippet     String              @db.Text
  sourceName  String?
  provider    String?
  confidence  Int?
  metadata    Json?
  createdAt   DateTime            @default(now())

  @@index([ownerId])
  @@index([candidateId])
  @@index([dealId])
  @@index([accountId])
}

model Touchpoint {
  id         String         @id @default(cuid())
  ownerId    String
  owner      User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountId  String?
  account    Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId     String?
  deal       Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  personId   String?
  person     Person?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  kind       TouchpointKind
  occurredAt DateTime       @default(now())
  summary    String
  body       String?        @db.Text
  outcome    String?
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([ownerId, occurredAt])
  @@index([accountId])
  @@index([dealId])
  @@index([personId])
}

model Task {
  id          String       @id @default(cuid())
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  personId    String?
  person      Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  title       String
  description String?      @db.Text
  dueAt       DateTime?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([ownerId, status])
  @@index([dueAt])
  @@index([dealId])
  @@index([accountId])
}

model ConversionAsset {
  id             String              @id @default(cuid())
  ownerId        String
  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountId      String?
  account        Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId         String?
  deal           Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  candidateId    String?
  candidate      DiscoveryCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  kind           ConversionAssetKind
  title          String?
  content        String              @db.Text
  model          String?
  promptSnapshot String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([ownerId])
  @@index([dealId])
  @@index([accountId])
  @@index([candidateId])
}

model DiscoveryRun {
  id           String    @id @default(cuid())
  sourceId     String?
  source       Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @default("RUNNING") // RUNNING | SUCCESS | ERROR | SKIPPED
  foundCount   Int       @default(0)
  newCount     Int       @default(0)
  updatedCount Int       @default(0)
  log          String?   @db.Text

  @@index([sourceId, startedAt])
}

model DiscoveryFeedback {
  id            String                @id @default(cuid())
  ownerId       String
  owner         User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  candidateId   String
  url           String?
  title         String
  candidateKind String?
  feedback      DiscoveryFeedbackType
  features      String[]              @default([])
  reason        String?
  sourceName    String?
  provider      String?
  query         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([ownerId, candidateId])
  @@index([ownerId, feedback])
  @@index([ownerId, url])
}

model Alert {
  id        String       @id @default(cuid())
  ownerId   String
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      AlertType
  channel   AlertChannel @default(LOCAL)
  title     String
  body      String?      @db.Text
  payload   Json?
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([ownerId, read])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
