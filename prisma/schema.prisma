// LEADer — Prisma schema (source of truth for the data model)
// Denmark-first, global-ready. Single power user now, multi-tenant-shaped (ownerId everywhere).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Workspace {
  DK
  GLOBAL
}

enum SourceType {
  PUBLIC_WEB // automatable
  RSS // automatable
  PROCUREMENT // automatable
  ACCELERATOR // automatable
  NEWSLETTER // automatable
  API // automatable
  FACEBOOK_MANUAL // manual-only (community lane)
  UPLOAD // manual-only
  MANUAL // manual-only
}

enum MonitorFrequency {
  MANUAL
  HOURLY
  DAILY
  WEEKLY
}

enum OpportunityStatus {
  NEW
  INTERESTING
  WATCH
  CONTACTED
  APPLIED
  WON
  LOST
  ARCHIVED
}

enum ApplicationRoute {
  DIRECT // direct contact / direct application
  APPLICATION // formal application process
  UNKNOWN
}

enum IngestMethod {
  AUTOMATED // public-source discovery
  MANUAL // user-created
  COMMUNITY // facebook/community import
}

enum DraftKind {
  SUMMARY
  APPLICATION
  PITCH
  EMAIL
  CHECKLIST
  COMPARISON
  EXPLANATION
}

enum ActivityType {
  CREATED
  STATUS_CHANGE
  NOTE
  AI_DRAFT
  SCORE
  EXPORT
  REMINDER
  IMPORT
  UPDATE
}

enum AlertType {
  DEADLINE
  NEW_HIGH_MATCH
  DIGEST
  NEEDS_ACTION
}

enum AlertChannel {
  LOCAL
  EMAIL
}

enum CommunityImportStatus {
  PENDING
  EXTRACTED
  CONFIRMED
  DISCARDED
}

// ─────────────────────────────── Models ──────────────────────────────

enum UserRole {
  OWNER
  MEMBER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String? // scrypt hash; null = no password set yet (legacy/dev seed)
  role         UserRole @default(OWNER)
  onboardedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Profile / preferences (drives scoring + AI context)
  headline             String? // e.g. "Fullstack dev · AI builder · MVP/product advisor"
  bio                  String?
  preferredProjectTypes String[] @default([])
  excludedCategories    String[] @default([])
  budgetMaxDkk          Int      @default(100000)
  preferredCurrency     String   @default("DKK")

  // JSON blobs (typed in lib/types.ts)
  scoringWeights Json? // ScoreWeights
  exportPrefs    Json? // ExportPreferences
  aiKeys         Json? // encrypted per-user AI provider config + masked key metadata

  sources        Source[]
  opportunities  Opportunity[]
  lists          List[]
  watchlistItems WatchlistItem[]
  savedSearches  SavedSearch[]
  alerts         Alert[]
  drafts         Draft[]
  notes          Note[]
  sessions       Session[]
}

// Server-side sessions (opaque token hashed at rest). The auth cookie holds the
// raw token; we store only its SHA-256 so a DB leak can't resurrect sessions.
model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Source {
  id           String           @id @default(cuid())
  ownerId      String
  owner        User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  url          String?
  type         SourceType
  workspace    Workspace        @default(DK)
  frequency    MonitorFrequency @default(DAILY)
  keywords     String[]         @default([])
  country      String?          @default("DK")
  region       String?
  category     String?
  enabled      Boolean          @default(true)
  parserKey    String? // maps to a site-specific extractor in lib/ingestion/parsers
  robotsAllowed Boolean?        // cached result of robots.txt check
  lastCheckedAt DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  opportunities  Opportunity[]
  discoveryRuns  DiscoveryRun[]

  @@index([ownerId, enabled])
  @@index([workspace])
}

model Opportunity {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceId    String?
  source      Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  title       String
  description String?  @db.Text
  rawContent  String?  @db.Text

  budgetMin   Int?
  budgetMax   Int?
  currency    String?  @default("DKK")

  deadline    DateTime?
  postedAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  url          String?
  organization String?
  location     String?
  country      String?   @default("DK")
  region       String?
  category     String?
  workspace    Workspace @default(DK)

  status           OpportunityStatus @default(NEW)
  applicationRoute ApplicationRoute  @default(UNKNOWN)
  priority         Int               @default(0) // 0..3
  ingestMethod     IngestMethod      @default(MANUAL)

  matchScore      Int?  // 0..100
  scoreBreakdown  Json? // ScoreBreakdown
  aiSummary       String? @db.Text
  whyRelevant     String? @db.Text
  nextAction      String? @db.Text
  extractedRequirements Json? // string[]

  // Semantic search: embedding vector + the model that produced it (only vectors
  // from the same model/dimension are comparable). Backfilled async; see lib/ai/embeddings.
  embedding      Float[]  @default([])
  embeddingModel String?
  embeddedAt     DateTime?

  dedupeHash String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts    Contact[]
  attachments Attachment[]
  notes       Note[]
  activities  Activity[]
  drafts      Draft[]
  tags        OpportunityTag[]
  listItems   ListItem[]
  watchlistItem WatchlistItem?
  communityImport CommunityImport?

  @@index([ownerId, status])
  @@index([ownerId, workspace])
  @@index([matchScore])
  @@index([deadline])
  @@index([sourceId])
}

model Contact {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  name          String?
  role          String?
  email         String?
  phone         String?
  organization  String?
  linkedin      String?
  createdAt     DateTime    @default(now())
}

model Attachment {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  label         String?
  url           String
  kind          String? // pdf | link | doc | image
  createdAt     DateTime    @default(now())
}

model Tag {
  id        String           @id @default(cuid())
  name      String           @unique
  color     String?
  createdAt DateTime         @default(now())
  opportunities OpportunityTag[]
}

model OpportunityTag {
  opportunityId String
  tagId         String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([opportunityId, tagId])
}

model Note {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body          String      @db.Text
  pinned        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model Activity {
  id            String       @id @default(cuid())
  opportunityId String
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type          ActivityType
  message       String
  metadata      Json?
  createdAt     DateTime     @default(now())

  @@index([opportunityId, createdAt])
}

model Draft {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  kind          DraftKind
  title         String?
  content       String      @db.Text
  model         String?
  promptSnapshot String?    @db.Text
  createdAt     DateTime    @default(now())

  @@index([opportunityId, kind])
}

model List {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       ListItem[]

  @@index([ownerId])
}

model ListItem {
  id            String      @id @default(cuid())
  listId        String
  list          List        @relation(fields: [listId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  addedAt       DateTime    @default(now())

  @@unique([listId, opportunityId])
}

model WatchlistItem {
  id            String      @id @default(cuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  priority      Int         @default(1) // 1..3
  reminderAt    DateTime?
  createdAt     DateTime    @default(now())

  @@index([ownerId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  filters   Json // OpportunityFilter
  createdAt DateTime @default(now())

  @@index([ownerId])
}

model CommunityImport {
  id            String                @id @default(cuid())
  ownerId       String
  groupName     String?
  author        String?
  postDate      DateTime?
  url           String?
  content       String                @db.Text
  notes         String?
  status        CommunityImportStatus @default(PENDING)
  extracted     Json? // AI-extracted candidate fields
  opportunityId String?               @unique
  opportunity   Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  @@index([ownerId, status])
}

model DiscoveryRun {
  id          String   @id @default(cuid())
  sourceId    String?
  source      Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  status      String   @default("RUNNING") // RUNNING | SUCCESS | ERROR | SKIPPED
  foundCount  Int      @default(0)
  newCount    Int      @default(0)
  updatedCount Int     @default(0)
  log         String?  @db.Text

  @@index([sourceId, startedAt])
}

model Alert {
  id        String       @id @default(cuid())
  ownerId   String
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      AlertType
  channel   AlertChannel @default(LOCAL)
  title     String
  body      String?      @db.Text
  payload   Json?
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([ownerId, read])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
